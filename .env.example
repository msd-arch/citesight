# --- Required ---
# SEC EDGAR requires a descriptive User-Agent with a contact email.
SEC_USER_AGENT="CiteSight/0.1 (research; contact: you@example.com)"

# --- LLM providers (all free-tier / local; NO paid APIs) ---
# Agent (router/verifier/composer) and eval judge are configured independently.
# Providers: groq | gemini | ollama | openai_compatible | self_vlm | fake
AGENT_LLM_PROVIDER=groq
# AGENT_LLM_MODEL=llama-3.3-70b-versatile
JUDGE_LLM_PROVIDER=gemini
# JUDGE_LLM_MODEL=gemini-2.0-flash

GROQ_API_KEY=""
GEMINI_API_KEY=""
# ollama needs no key (http://localhost:11434/v1, default model qwen2.5:7b-instruct)

# any other OpenAI-compatible endpoint:
# OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_MODEL=
# OPENAI_COMPATIBLE_API_KEY=

# free-tier protection
# LLM_REQUESTS_PER_MIN=25
# LLM_CACHE_ENABLED=false

# --- Tracing: langfuse | local | off ---
# local (default) writes JSONL spans to data/traces; CI should use off.
# Langfuse Cloud free tier (interactive app only — eval always uses local):
TRACING=local
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Optional overrides (defaults shown) ---
# QDRANT_MODE=embedded            # embedded | server
# QDRANT_URL=http://localhost:6333
# DEVICE=auto                     # auto | cuda | mps | cpu
# POOLING_ENABLED=false
# POOL_FACTOR=3
# EMBED_BATCH_SIZE=2
# RENDER_DPI=150
# VLM_VARIANT=7b                  # 3b | 7b | 32b
# VLM_BACKEND=transformers        # transformers | vllm (Linux only)
# VLM_QUANTIZE_4BIT=true
# AGENT_MAX_ATTEMPTS=2
